{% extends "layout.njk" %}

{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  {{ govukPanel({
    titleText: "Deletion complete",
    html: result.paymentCount + " payment records and " + result.schemeCount + " scheme records for financial year " + financialYear + " have been deleted"
  }) }}

  <p class="govuk-body">
    {{ govukButton({
      text: "Return to manage payments",
      href: "/admin/payments",
      classes: "govuk-button--secondary"
    }) }}
  </p>
{% endblock %}
