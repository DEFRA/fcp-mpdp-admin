{% extends "layout.njk" %}

{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block containerStart %}
  {{ super() }}
  {% if errorMessage %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [{ text: errorMessage }]
    }) }}
  {% endif %}
  {{ govukBackLink({
    text: "Back",
    href: "/admin/payment-summary"
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ pageTitle }}</h1>

      <form method="POST" action="/admin/payment-summary/edit/{{ summary.id }}">
        <input type="hidden" name="crumb" value="{{ crumb }}">

        {{ govukInput({
          label: { text: "Financial year" },
          id: "financialYear",
          name: "financialYear",
          classes: "govuk-input--width-10",
          value: summary.financialYear,
          attributes: { maxlength: "8" }
        }) }}

        {{ govukInput({
          label: { text: "Scheme" },
          id: "scheme",
          name: "scheme",
          value: summary.scheme
        }) }}

        {{ govukInput({
          label: { text: "Total amount" },
          id: "totalAmount",
          name: "totalAmount",
          classes: "govuk-input--width-10",
          value: summary.totalAmount,
          prefix: { text: "£" },
          type: "number",
          attributes: { step: "0.01" }
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({ text: "Update payment summary" }) }}
          <a class="govuk-link" href="/admin/payment-summary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
