# Copy this file to .env for local development.
# Real environment variables always take precedence over this file.
# .env is gitignored — never commit it.

# Server
PORT=3003
NODE_ENV=development

# Backend API
MPDP_BACKEND_ENDPOINT=http://localhost:3001

# Microsoft Entra (OIDC) authentication
ENTRA_TENANT_ID=your-tenant-id
ENTRA_WELL_KNOWN_URL=https://login.microsoftonline.com/your-tenant-id/v2.0/.well-known/openid-configuration
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_REDIRECT_URL=http://localhost:3003/auth/sign-in-oidc
ENTRA_SIGN_OUT_REDIRECT_URL=http://localhost:3003/auth/sign-out-oidc

# Redis session cache
REDIS_HOST=localhost

# Session cookie (must be at least 32 characters)
COOKIE_PASSWORD=this-is-a-secret-that-must-be-at-least-32-characters

# AWS STS federated credentials (alternative to ENTRA_CLIENT_SECRET in CDP environments)
# FEDERATED_CREDENTIALS_ENABLED=false

# Service-to-service authentication (disabled by default)
# SERVICE_AUTH_ENABLED=false
